  <article>
    <nav class="mb-6 text-sm">
      <a href={localizedPath(lang)} class="text-crt-amber-dim underline-offset-2 hover:text-crt-amber hover:underline">
        ← {copy.back}
      </a>
    </nav>

    <header class="mb-10">
      <p class="font-pixel text-xs tracking-widest text-crt-amber-dim">{copy.kicker}</p>
      <h1 class="mt-3 font-pixel text-3xl text-crt-amber crt-glow md:text-5xl">{copy.title}</h1>
      <p class="mt-6 max-w-3xl text-base leading-relaxed text-crt-text/85 md:text-lg">{copy.intro}</p>
    </header>

    <section class="grid gap-5 md:grid-cols-3">
      <a href={localizedPath(lang, '/consoles/mega-drive/')} class="group block border border-crt-dim/45 bg-crt-panel/35 transition hover:border-crt-amber/65 hover:bg-crt-panel/60">
        <img src="/img/consoles/thumbs/mega-drive-hero-640.webp" alt="" class="aspect-video w-full object-cover border-b border-crt-dim/35 transition group-hover:brightness-110" loading="eager" />
        <div class="p-5">
          <h2 class="font-pixel text-sm text-crt-amber">{copy.megaDrive}</h2>
          <p class="mt-3 text-sm text-crt-text/70">{copy.viewMega}</p>
        </div>
      </a>
      <a href={localizedPath(lang, '/consoles/saturn/')} class="group block border border-crt-dim/45 bg-crt-panel/35 transition hover:border-crt-amber/65 hover:bg-crt-panel/60">
        <img src="/img/consoles/thumbs/saturn-hero-640.webp" alt="" class="aspect-video w-full object-cover border-b border-crt-dim/35 transition group-hover:brightness-110" loading="eager" />
        <div class="p-5">
          <h2 class="font-pixel text-sm text-crt-amber">{copy.saturn}</h2>
          <p class="mt-3 text-sm text-crt-text/70">{copy.viewSaturn}</p>
        </div>
      </a>
      <a href={localizedPath(lang, '/consoles/dreamcast/')} class="group block border border-crt-dim/45 bg-crt-panel/35 transition hover:border-crt-amber/65 hover:bg-crt-panel/60">
        <img src="/img/consoles/thumbs/dreamcast-hero-640.webp" alt="" class="aspect-video w-full object-cover border-b border-crt-dim/35 transition group-hover:brightness-110" loading="eager" />
        <div class="p-5">
          <h2 class="font-pixel text-sm text-crt-amber">{copy.dreamcast}</h2>
          <p class="mt-3 text-sm text-crt-text/70">{copy.viewDreamcast}</p>
        </div>
      </a>
    </section>

    <section class="my-12 grid gap-4 md:grid-cols-3">
      {copy.sections.map((section) => (
        <div class="border-l-2 border-crt-amber/65 bg-crt-panel/25 p-5">
          <h2 class="font-pixel text-xs leading-relaxed text-crt-amber">{section.title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-crt-text/78">{section.body}</p>
        </div>
      ))}
    </section>

    {deepDive && (
      <>
        <section class="my-12">
          <h2 class="mb-4 font-pixel text-xs uppercase tracking-wider text-crt-amber">{deepDive.anatomyTitle}</h2>
          <div class="grid gap-4 md:grid-cols-3">
            {deepDive.anatomy.map((item) => (
              <div class="border border-crt-dim/40 bg-crt-panel/30 p-5">
                <h3 class="font-pixel text-xs leading-relaxed text-crt-green">{item.label}</h3>
                <p class="mt-3 text-sm leading-relaxed text-crt-text/78">{item.body}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="my-12 border-y border-crt-amber/25 py-6">
          <h2 class="mb-4 font-pixel text-xs uppercase tracking-wider text-crt-amber">{deepDive.mythTitle}</h2>
          <div class="space-y-4">
            {deepDive.myths.map((item) => (
              <div class="grid gap-3 md:grid-cols-[16rem_minmax(0,1fr)]">
                <div class="border-l-2 border-crt-amber/70 pl-4 text-sm leading-relaxed text-crt-amber-dim">{item.myth}</div>
                <p class="text-sm leading-relaxed text-crt-text/82">{item.fact}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="my-12">
          <h2 class="mb-4 font-pixel text-xs uppercase tracking-wider text-crt-amber">{deepDive.nintendoTitle}</h2>
          <div class="grid gap-4 md:grid-cols-3">
            {deepDive.nintendoMoves.map((move) => (
              <div class="border-l-2 border-crt-green/65 pl-4">
                <h3 class="font-mono text-xs text-crt-amber-dim">{move.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-crt-text/82">{move.body}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="my-12">
          <h2 class="mb-4 font-pixel text-xs uppercase tracking-wider text-crt-amber">{deepDive.gamesTitle}</h2>
          <div class="grid gap-5 md:grid-cols-2">
            {deepDive.gamePicks.map((platform) => (
              <div class="border border-crt-dim/40 bg-crt-panel/30 p-5">
                <h3 class="font-pixel text-xs leading-relaxed text-crt-green">{platform.platform}</h3>
                <ol class="mt-4 space-y-3">
                  {platform.games.map(([title, reason]) => (
                    <li class="border-b border-crt-dim/25 pb-3 last:border-b-0 last:pb-0">
                      <div class="font-mono text-xs text-crt-amber-dim">{title}</div>
                      <p class="mt-1 text-sm leading-relaxed text-crt-text/78">{reason}</p>
                    </li>
                  ))}
                </ol>
              </div>
            ))}
          </div>
        </section>

        <section class="my-12">
          <h2 class="mb-4 font-pixel text-xs uppercase tracking-wider text-crt-amber">{deepDive.storiesTitle}</h2>
          <div class="grid gap-4 md:grid-cols-2">
            {deepDive.stories.map((story) => (
              <div class="border border-crt-dim/35 bg-crt-bg/35 p-5">
                <h3 class="font-pixel text-xs leading-relaxed text-crt-amber">{story.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-crt-text/78">{story.body}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="my-12 border border-crt-dim/35 bg-crt-bg/35 p-5">
          <h2 class="font-pixel text-xs uppercase tracking-wider text-crt-amber">{deepDive.sourcesTitle}</h2>
          <p class="mt-3 text-xs leading-relaxed text-crt-text/62">{deepDive.sources}</p>
        </section>
      </>
    )}

    <section class="border-y border-crt-green/30 py-6">
      <p class="max-w-3xl text-base leading-relaxed text-crt-text/85">{copy.takeaway}</p>
    </section>
  </article>
</BaseLayout>
