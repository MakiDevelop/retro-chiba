---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, localizedPath } from '../i18n/utils';
import { makeUrl } from '../data/seo';
import type { Lang } from '../i18n/ui';
import { generations, type GenKey } from '../data/generations';
import consolesData from '../data/consoles.json';

interface ConsoleEntry {
  qid: string;
  slug: string;
  gen: string;
  kind: string;
  names: Record<string, string>;
  maker: string;
  first_release: string;
}

interface Props {
  gen: GenKey;
  lang: Lang;
}

const { gen, lang } = Astro.props;
const t = useTranslations(lang);
const info = generations[gen];

const allConsoles = (consolesData as ConsoleEntry[]).filter((c) => c.gen === gen);
allConsoles.sort((a, b) => (a.first_release || '9999').localeCompare(b.first_release || '9999'));

const fullEntries = await getCollection('consoles', (e) => e.data.lang === lang);
const fullSlugs = new Set(fullEntries.map((e) => e.id.split('/')[0]));

const buildingLabel = {
  'zh-tw': '建造中',
  'zh-cn': '建造中',
  en: 'Under construction',
  ja: '建設中',
}[lang];
---

<BaseLayout
  title={info.titles[lang]}
  description={info.summaries[lang]}
  keywords={[info.titles[lang], info.period, 'video game console generation']}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: info.titles[lang],
    description: info.summaries[lang],
    url: makeUrl(localizedPath(lang, `generations/${gen}/`)),
    about: 'Video game console history',
  }}
>
  <article>
    <nav class="mb-6 text-sm">
      <a href={localizedPath(lang)} class="text-crt-amber-dim underline-offset-2 hover:text-crt-amber hover:underline">
        ← {t('gen.back')}
      </a>
    </nav>

    <header class="mb-10">
      <p class="font-pixel text-xs tracking-widest text-crt-amber-dim">[ {info.period} ]</p>
      <h1 class="mt-2 font-pixel text-2xl text-crt-amber crt-glow md:text-4xl">{info.titles[lang]}</h1>
      <p class="mt-6 max-w-3xl text-base leading-relaxed text-crt-text/85">{info.summaries[lang]}</p>
    </header>

    <section>
      <h2 class="mb-4 font-pixel text-xs uppercase tracking-wider text-crt-amber">{t('gen.consoles')}</h2>
      {allConsoles.length === 0 ? (
        <p class="text-sm text-crt-text/60">—</p>
      ) : (
        <ul class="grid gap-4 md:grid-cols-2">
          {allConsoles.map((c) => {
            const isFull = fullSlugs.has(c.slug);
            const displayName = c.names[lang] || c.names.en || c.slug;
            const thumbBase = `/img/consoles/thumbs/${c.slug}-hero`;
            const cardClass = isFull
              ? 'group block overflow-hidden rounded-xl border border-crt-dim/40 bg-crt-panel/40 transition hover:-translate-y-0.5 hover:border-crt-amber/60 hover:bg-crt-panel/65'
              : 'group block overflow-hidden rounded-xl border border-crt-dim/30 bg-crt-panel/20 opacity-80';
            const inner = (
              <>
                <div class="aspect-video overflow-hidden border-b border-crt-dim/30 bg-crt-bg/50">
                  <img
                    src={`${thumbBase}-640.webp`}
                    srcset={`${thumbBase}-320.webp 320w, ${thumbBase}-640.webp 640w`}
                    sizes="(min-width: 768px) 44vw, 92vw"
                    alt={displayName}
                    width="640"
                    height="360"
                    class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="p-5">
                  <div class="font-pixel text-sm leading-relaxed text-crt-amber">{displayName}</div>
                  <div class="mt-1 text-xs text-crt-text/60">{c.maker || '—'}</div>
                  {c.first_release && (
                    <div class="mt-2 font-mono text-xs text-crt-text/45">{c.first_release}</div>
                  )}
                  {!isFull && (
                    <div class="mt-3 inline-block rounded border border-crt-dim/40 px-2 py-0.5 text-[10px] uppercase tracking-wider text-crt-text/50">
                      {buildingLabel}
                    </div>
                  )}
                </div>
              </>
            );
            return (
              <li>
                {isFull ? (
                  <a href={localizedPath(lang, `/consoles/${c.slug}/`)} class={cardClass}>{inner}</a>
                ) : (
                  <div class={cardClass}>{inner}</div>
                )}
              </li>
            );
          })}
        </ul>
      )}
    </section>
  </article>
</BaseLayout>
