---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Figcaption from './Figcaption.astro';
import YouTubeEmbed from './YouTubeEmbed.astro';
import ConsoleSpecs from './ConsoleSpecs.astro';
import { useTranslations, localizedPath } from '../i18n/utils';
import { makeUrl } from '../data/seo';
import type { Lang } from '../i18n/ui';

interface Props {
  entry: CollectionEntry<'consoles'>;
  lang: Lang;
}

const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(entry);
const d = entry.data;
const slug = entry.id.split('/')[0];
const hasLightbox = Boolean(d.images.hero || d.images.gallery.length > 0);
const consoleDescription =
  d.curation.thesis ??
  d.curation.turning_point ??
  `${d.title} 是第 ${d.gen} 世代遊戲主機展品，收錄硬體規格、發行日期、銷量、代表作與策展筆記。`;

const specsI18n = {
  specsTitle: t('console.specs'),
  releaseTitle: t('console.release'),
  salesTitle: t('console.sales'),
  maker: t('console.maker'),
  jp: t('console.jp'),
  na: t('console.na'),
  eu: t('console.eu'),
  official: t('console.official'),
  community: t('console.community'),
};

const curationLabels = {
  'zh-tw': {
    title: '策展筆記',
    thesis: '這台機器代表什麼',
    turningPoint: '歷史轉折',
    localMemory: '中文圈記憶',
    curatedGames: '策展推薦',
    related: '延伸展品',
  },
  'zh-cn': {
    title: '策展笔记',
    thesis: '这台机器代表什么',
    turningPoint: '历史转折',
    localMemory: '中文圈记忆',
    curatedGames: '策展推荐',
    related: '延伸展品',
  },
  en: {
    title: 'Curator Notes',
    thesis: 'What this machine stands for',
    turningPoint: 'Turning point',
    localMemory: 'Regional memory',
    curatedGames: 'Curated picks',
    related: 'Related exhibits',
  },
  ja: {
    title: 'キュレーターズノート',
    thesis: 'この機種が象徴するもの',
    turningPoint: '歴史の転換点',
    localMemory: '地域の記憶',
    curatedGames: 'キュレーション選',
    related: '関連展示',
  },
}[lang];

const hasCuration = Boolean(d.curation.thesis || d.curation.turning_point || d.curation.local_memory);
---

<BaseLayout
  title={d.title}
  description={consoleDescription}
  image={d.images.hero?.src}
  keywords={[d.title, d.maker, `generation ${d.gen}`, 'video game console']}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: d.title,
    description: consoleDescription,
    image: d.images.hero?.src ? makeUrl(d.images.hero.src) : undefined,
    brand: { '@type': 'Brand', name: d.maker },
    category: 'Video game console',
    url: makeUrl(localizedPath(lang, `consoles/${slug}/`)),
  }}
>
  <article>
    <nav class="mb-6 text-sm">
      <a href={localizedPath(lang, `/generations/${d.gen}/`)} class="text-crt-amber-dim underline-offset-2 hover:text-crt-amber hover:underline">
        ← {t('console.back', { n: String(d.gen) })}
      </a>
    </nav>

    <header class="mb-8">
      <p class="font-pixel text-xs tracking-widest text-crt-amber-dim">
        [ GEN {d.gen} · {d.maker} ]
      </p>
      <h1 class="mt-2 font-pixel text-2xl text-crt-amber crt-glow md:text-4xl">
        {d.title}
      </h1>
    </header>

    <div data-console-lightbox-root>
      {d.images.hero && (
        <figure class="my-6">
          <button
            type="button"
            class="group block w-full cursor-zoom-in text-left"
            data-lightbox-trigger
            data-lightbox-src={d.images.hero.src}
            data-lightbox-alt={d.images.hero.alt ?? d.title}
            data-lightbox-caption={d.images.hero.caption ?? ''}
            aria-haspopup="dialog"
          >
            <img
              src={d.images.hero.src}
              alt={d.images.hero.alt ?? ''}
              class="w-full rounded border border-crt-dim/40 transition duration-300 group-hover:border-crt-amber/70"
              loading="eager"
            />
          </button>
          <Figcaption {...d.images.hero} />
        </figure>
      )}

      {d.images.gallery.length > 0 && (
        <section class="my-10">
          <h2 class="mb-3 font-pixel text-xs uppercase tracking-wider text-crt-amber">{t('console.gallery')}</h2>
          <div class="grid gap-6 md:grid-cols-2">
            {d.images.gallery.map((g) => (
              <figure>
                <button
                  type="button"
                  class="group block w-full cursor-zoom-in text-left"
                  data-lightbox-trigger
                  data-lightbox-src={g.src}
                  data-lightbox-alt={g.alt ?? d.title}
                  data-lightbox-caption={g.caption ?? ''}
                  aria-haspopup="dialog"
                >
                  <img
                    src={g.src}
                    alt={g.alt ?? ''}
                    class="w-full rounded border border-crt-dim/40 transition duration-300 group-hover:border-crt-amber/70"
                    loading="lazy"
                  />
                </button>
                <Figcaption {...g} />
              </figure>
            ))}
          </div>
        </section>
      )}

      {hasLightbox && (
        <>
          <dialog
            data-lightbox-dialog
            class="m-0 w-[min(92vw,1100px)] max-w-none overflow-hidden rounded-xl border border-crt-amber/70 bg-crt-bg/95 p-0 text-crt-text shadow-[0_0_35px_rgba(255,176,0,0.12)] backdrop:bg-black/85"
          >
            <div class="relative">
              <button
                type="button"
                data-lightbox-close
                aria-label={t('console.lightboxClose')}
                class="absolute right-3 top-3 z-10 flex h-10 w-10 items-center justify-center rounded-full border border-crt-amber/45 bg-crt-bg/80 font-mono text-lg text-crt-amber transition hover:border-crt-amber hover:bg-crt-panel/95"
              >
                ×
              </button>
              <img data-lightbox-image alt="" class="max-h-[82vh] w-full bg-black object-contain" />
              <p
                data-lightbox-caption
                class="border-t border-crt-dim/50 px-4 py-3 text-sm leading-relaxed text-crt-text/80"
                hidden
              ></p>
            </div>
          </dialog>

          <script is:inline>
            for (const root of document.querySelectorAll('[data-console-lightbox-root]')) {
              const dialog = root.querySelector('[data-lightbox-dialog]');
              const image = root.querySelector('[data-lightbox-image]');
              const caption = root.querySelector('[data-lightbox-caption]');
              const close = root.querySelector('[data-lightbox-close]');

              if (!(dialog instanceof HTMLDialogElement) || !(image instanceof HTMLImageElement) || !(caption instanceof HTMLElement)) {
                continue;
              }

              const closeDialog = () => {
                if (dialog.open) {
                  dialog.close();
                }
              };

              const openDialog = (trigger) => {
                const src = trigger.getAttribute('data-lightbox-src');
                if (!src) {
                  return;
                }

                image.src = src;
                image.alt = trigger.getAttribute('data-lightbox-alt') || '';

                const text = trigger.getAttribute('data-lightbox-caption') || '';
                caption.textContent = text;
                caption.hidden = text.length === 0;

                dialog.showModal();
                document.body.style.overflow = 'hidden';
              };

              for (const trigger of root.querySelectorAll('[data-lightbox-trigger]')) {
                trigger.addEventListener('click', () => openDialog(trigger));
              }

              close?.addEventListener('click', closeDialog);
              dialog.addEventListener('click', (event) => {
                if (event.target === dialog) {
                  closeDialog();
                }
              });
              dialog.addEventListener('close', () => {
                image.removeAttribute('src');
                image.alt = '';
                caption.textContent = '';
                caption.hidden = true;
                document.body.style.overflow = '';
              });
            }
          </script>
        </>
      )}
    </div>

    <ConsoleSpecs
      specs={d.specs}
      release={d.release}
      sales={d.sales}
      maker={d.maker}
      i18n={specsI18n}
    />

    {(hasCuration || d.curated_games.length > 0) && (
      <section class="my-12 border-y border-crt-amber/25 bg-crt-panel/25 py-6">
        <h2 class="font-pixel text-xs uppercase tracking-wider text-crt-amber">{curationLabels.title}</h2>
        {hasCuration && (
          <div class="mt-5 grid gap-4 md:grid-cols-3">
            {d.curation.thesis && (
              <div class="border-l-2 border-crt-amber/70 pl-4">
                <h3 class="font-mono text-[11px] uppercase tracking-[0.22em] text-crt-amber-dim">{curationLabels.thesis}</h3>
                <p class="mt-2 text-sm leading-relaxed text-crt-text/82">{d.curation.thesis}</p>
              </div>
            )}
            {d.curation.turning_point && (
              <div class="border-l-2 border-crt-green/70 pl-4">
                <h3 class="font-mono text-[11px] uppercase tracking-[0.22em] text-crt-green/80">{curationLabels.turningPoint}</h3>
                <p class="mt-2 text-sm leading-relaxed text-crt-text/82">{d.curation.turning_point}</p>
              </div>
            )}
            {d.curation.local_memory && (
              <div class="border-l-2 border-crt-dim pl-4">
                <h3 class="font-mono text-[11px] uppercase tracking-[0.22em] text-crt-text/55">{curationLabels.localMemory}</h3>
                <p class="mt-2 text-sm leading-relaxed text-crt-text/82">{d.curation.local_memory}</p>
              </div>
            )}
          </div>
        )}

        {d.curated_games.length > 0 && (
          <div class="mt-8">
            <h3 class="mb-3 font-pixel text-xs uppercase tracking-wider text-crt-amber">{curationLabels.curatedGames}</h3>
            <ol class="grid gap-3 md:grid-cols-3">
              {d.curated_games.map((g) => (
                <li class="border border-crt-dim/35 bg-crt-bg/35 p-4">
                  <div class="font-pixel text-xs leading-relaxed text-crt-amber">{g.title}</div>
                  <p class="mt-2 text-sm leading-relaxed text-crt-text/78">{g.reason}</p>
                </li>
              ))}
            </ol>
          </div>
        )}
      </section>
    )}

    <div class="prose prose-invert prose-crt max-w-none">
      <Content />
    </div>

    {d.notable_games.length > 0 && (
      <section class="my-12 rounded border border-crt-dim/40 bg-crt-panel/40 p-5">
        <h2 class="mb-3 font-pixel text-xs uppercase tracking-wider text-crt-amber">{t('console.notable')}</h2>
        <ul class="grid gap-2 text-sm md:grid-cols-2">
          {d.notable_games.map((g) => (
            <li class="border-l-2 border-crt-amber-dim/60 pl-3 text-crt-text/85">{g}</li>
          ))}
        </ul>
      </section>
    )}

    {d.related_consoles.length > 0 && (
      <section class="my-12">
        <h2 class="mb-4 font-pixel text-xs uppercase tracking-wider text-crt-amber">{curationLabels.related}</h2>
        <ul class="grid gap-3 md:grid-cols-3">
          {d.related_consoles.map((item) => (
            <li>
              <a
                href={localizedPath(lang, `/consoles/${item.slug}/`)}
                class="block h-full border border-crt-dim/40 bg-crt-panel/35 p-4 transition hover:border-crt-amber/65 hover:bg-crt-panel/60"
              >
                <div class="font-pixel text-xs leading-relaxed text-crt-amber">{item.label}</div>
                <p class="mt-2 text-sm leading-relaxed text-crt-text/72">{item.note}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {d.videos.length > 0 && (
      <section class="my-12">
        <h2 class="mb-3 font-pixel text-xs uppercase tracking-wider text-crt-amber">{t('console.video')}</h2>
        {d.videos.map((v) => <YouTubeEmbed id={v.youtube} caption={v.caption} source={v.source} />)}
      </section>
    )}
  </article>
</BaseLayout>
