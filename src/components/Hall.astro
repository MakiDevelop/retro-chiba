---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import { generations, allGenKeys } from '../data/generations';
import consolesData from '../data/consoles.json';

interface ConsoleEntry { gen: string; }

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const counts = (consolesData as ConsoleEntry[]).reduce<Record<string, number>>((acc, c) => {
  acc[c.gen] = (acc[c.gen] || 0) + 1;
  return acc;
}, {});

const consoleLabel = {
  'zh-tw': '台主機',
  'zh-cn': '台主机',
  en: 'consoles',
  ja: '機種',
}[lang];

const homeGens = allGenKeys.filter((g) => g !== 'h');
const timelineEntries = [
  ...homeGens.map((g) => ({
    key: g,
    branch: 'main' as const,
    href: localizedPath(lang, `/generations/${g}/`),
    marker: `Gen ${g}`,
    count: counts[g] || 0,
    info: generations[g],
  })),
  {
    key: 'h',
    branch: 'handheld' as const,
    href: localizedPath(lang, '/generations/h/'),
    marker: t('home.handheldMark'),
    count: counts.h || 0,
    info: generations.h,
  },
];

const featureCopies = {
  'zh-tw': {
    eyebrow: '[ SPECIAL EXHIBITIONS ]',
    cta: '進入專題展',
    items: [
      {
        href: '/features/atari-crash/',
        title: 'Atari 大崩潰',
        body: 'Atari 2600 盛世後，北美家用主機市場因供給過剩、品質失控與零售信任崩壞而急凍。任天堂後來的 NES 復興，就是從修復這場崩潰開始。',
        images: ['/img/consoles/thumbs/atari-2600-hero-320.webp', '/img/consoles/thumbs/famicom-hero-320.webp'],
      },
      {
        href: '/features/16-bit-war/',
        title: '16-bit 戰爭',
        body: 'Mega Drive 用速度與攻擊型廣告挑戰任天堂；Super Famicom 用色彩、聲音與 RPG 陣容守住主流。從這裡開始，主機戰不再只是規格表。',
        images: ['/img/consoles/thumbs/super-famicom-hero-320.webp', '/img/consoles/thumbs/mega-drive-hero-320.webp'],
      },
      {
        href: '/features/playstation-breakup/',
        title: 'PlayStation 誕生前夜',
        body: '任天堂與 Sony 的 SFC CD-ROM 合作破局，讓原本的周邊計畫變成獨立主機。主機戰有時不是從店頭開始，而是從合約翻臉開始。',
        images: ['/img/consoles/thumbs/super-famicom-hero-320.webp', '/img/consoles/thumbs/ps1-hero-320.webp'],
      },
      {
        href: '/features/polygon-revolution/',
        title: '多邊形革命',
        body: 'PlayStation、Saturn、Nintendo 64 把主機戰推進 CD-ROM、3D 空間、記憶卡與類比操作。現代遊戲的輪廓在這代第一次成形。',
        images: ['/img/consoles/thumbs/ps1-hero-320.webp', '/img/consoles/thumbs/n64-hero-320.webp'],
      },
      {
        href: '/features/sega-exit/',
        title: 'Sega 的退場',
        body: '從 Saturn 1995 E3 突襲、32X / Sega CD 的內耗，到 Dreamcast 被 PS2 用 DVD 木馬屠城——Sega 退出主機事業，不是一次崩潰，而是七年的自我拆解。',
        images: ['/img/consoles/thumbs/saturn-hero-320.webp', '/img/consoles/thumbs/dreamcast-hero-320.webp'],
      },
      {
        href: '/features/gray-memory/',
        title: '華人圈灰色記憶',
        body: '小霸王學習機、神遊機、Gamate、Super A\'Can、Watara Supervision——1987-2007 華人圈灰色硬體史，與正版任天堂時間線完全平行的另一條主機記憶。',
        images: ['/img/consoles/thumbs/famicom-hero-320.webp', '/img/consoles/thumbs/n64-hero-320.webp'],
      },
      {
        href: '/features/handheld-wars/',
        title: '掌機戰爭三部曲',
        body: '1989 年 GB 用單色螢幕打敗彩色 Lynx；2004 年 DS 用觸控反吃 PSP；2011 年 Vita 被 iPhone 屠殺。掌機戰爭三幕 30 年史，最後 Switch 用「跳出戰場」結束戰爭。',
        images: ['/img/consoles/thumbs/game-boy-hero-320.webp', '/img/consoles/thumbs/nintendo-ds-hero-320.webp'],
      },
    ],
  },
  'zh-cn': {
    eyebrow: '[ SPECIAL EXHIBITIONS ]',
    cta: '进入专题展',
    items: [
      {
        href: '/features/atari-crash/',
        title: 'Atari 大崩溃',
        body: 'Atari 2600 盛世后，北美家用主机市场因供给过剩、品质失控与零售信任崩坏而急冻。任天堂后来的 NES 复兴，就是从修复这场崩溃开始。',
        images: ['/img/consoles/thumbs/atari-2600-hero-320.webp', '/img/consoles/thumbs/famicom-hero-320.webp'],
      },
      {
        href: '/features/16-bit-war/',
        title: '16-bit 战争',
        body: 'Mega Drive 用速度与攻击型广告挑战任天堂；Super Famicom 用色彩、声音与 RPG 阵容守住主流。从这里开始，主机战不再只是规格表。',
        images: ['/img/consoles/thumbs/super-famicom-hero-320.webp', '/img/consoles/thumbs/mega-drive-hero-320.webp'],
      },
      {
        href: '/features/playstation-breakup/',
        title: 'PlayStation 诞生前夜',
        body: '任天堂与 Sony 的 SFC CD-ROM 合作破局，让原本的周边计划变成独立主机。主机战有时不是从店头开始，而是从合约翻脸开始。',
        images: ['/img/consoles/thumbs/super-famicom-hero-320.webp', '/img/consoles/thumbs/ps1-hero-320.webp'],
      },
      {
        href: '/features/polygon-revolution/',
        title: '多边形革命',
        body: 'PlayStation、Saturn、Nintendo 64 把主机战推进 CD-ROM、3D 空间、记忆卡与模拟操作。现代游戏的轮廓在这代第一次成形。',
        images: ['/img/consoles/thumbs/ps1-hero-320.webp', '/img/consoles/thumbs/n64-hero-320.webp'],
      },
      {
        href: '/features/sega-exit/',
        title: 'Sega 的退场',
        body: '从 Saturn 1995 E3 突袭、32X / Sega CD 的内耗，到 Dreamcast 被 PS2 用 DVD 木马屠城——Sega 退出主机事业，不是一次崩溃，而是七年的自我拆解。',
        images: ['/img/consoles/thumbs/saturn-hero-320.webp', '/img/consoles/thumbs/dreamcast-hero-320.webp'],
      },
      {
        href: '/features/gray-memory/',
        title: '华人圈灰色记忆',
        body: '小霸王学习机、神游机、Gamate、Super A\'Can、Watara Supervision——1987-2007 华人圈灰色硬体史，与正版任天堂时间线完全平行的另一条主机记忆。',
        images: ['/img/consoles/thumbs/famicom-hero-320.webp', '/img/consoles/thumbs/n64-hero-320.webp'],
      },
      {
        href: '/features/handheld-wars/',
        title: '掌机战争三部曲',
        body: '1989 年 GB 用单色屏幕打败彩色 Lynx；2004 年 DS 用触控反吃 PSP；2011 年 Vita 被 iPhone 屠杀。掌机战争三幕 30 年史，最后 Switch 用「跳出战场」结束战争。',
        images: ['/img/consoles/thumbs/game-boy-hero-320.webp', '/img/consoles/thumbs/nintendo-ds-hero-320.webp'],
      },
    ],
  },
  en: {
    eyebrow: '[ SPECIAL EXHIBITIONS ]',
    cta: 'Enter exhibit',
    items: [
      {
        href: '/features/atari-crash/',
        title: 'The Atari Crash',
        body: 'After the Atari 2600 boom, North American consoles froze under oversupply, weak quality control, and broken retailer trust. NES revival started by repairing that damage.',
        images: ['/img/consoles/thumbs/atari-2600-hero-320.webp', '/img/consoles/thumbs/famicom-hero-320.webp'],
      },
      {
        href: '/features/16-bit-war/',
        title: 'The 16-bit War',
        body: 'Mega Drive challenged Nintendo with speed and attack advertising; Super Famicom answered with color, sound, and RPG gravity. From here on, console wars were no longer just spec sheets.',
        images: ['/img/consoles/thumbs/super-famicom-hero-320.webp', '/img/consoles/thumbs/mega-drive-hero-320.webp'],
      },
      {
        href: '/features/playstation-breakup/',
        title: 'Before PlayStation',
        body: 'Nintendo and Sony’s SFC CD-ROM partnership collapsed, turning an accessory plan into an independent console. Sometimes console wars begin in contracts.',
        images: ['/img/consoles/thumbs/super-famicom-hero-320.webp', '/img/consoles/thumbs/ps1-hero-320.webp'],
      },
      {
        href: '/features/polygon-revolution/',
        title: 'The Polygon Revolution',
        body: 'PlayStation, Saturn, and Nintendo 64 moved console competition into CD-ROM, 3D space, memory cards, and analog control. Modern games took shape here first.',
        images: ['/img/consoles/thumbs/ps1-hero-320.webp', '/img/consoles/thumbs/n64-hero-320.webp'],
      },
      {
        href: '/features/sega-exit/',
        title: 'How Sega Left the Console Business',
        body: 'From the 1995 Saturn E3 surprise launch and the 32X / Sega CD bleed-out to Dreamcast falling against PS2’s built-in DVD player — Sega did not crash. It dismantled itself over seven years.',
        images: ['/img/consoles/thumbs/saturn-hero-320.webp', '/img/consoles/thumbs/dreamcast-hero-320.webp'],
      },
      {
        href: '/features/gray-memory/',
        title: 'The Gray-Market Memory of the Chinese-Speaking World',
        body: 'Subor learning machines, iQue Player, Gamate, Super A\'Can, Watara Supervision — a 1987-2007 history of gray-market hardware that ran in parallel to the licensed Nintendo timeline.',
        images: ['/img/consoles/thumbs/famicom-hero-320.webp', '/img/consoles/thumbs/n64-hero-320.webp'],
      },
      {
        href: '/features/handheld-wars/',
        title: 'The Three Acts of the Handheld Wars',
        body: 'Game Boy beat color with monochrome (1989); Nintendo DS beat optical discs with touch (2004); iPhone killed PS Vita (2011). A thirty-year, three-act history of the handheld wars — and how Switch ended the war by walking off the battlefield.',
        images: ['/img/consoles/thumbs/game-boy-hero-320.webp', '/img/consoles/thumbs/nintendo-ds-hero-320.webp'],
      },
    ],
  },
  ja: {
    eyebrow: '[ SPECIAL EXHIBITIONS ]',
    cta: '展示へ',
    items: [
      {
        href: '/features/atari-crash/',
        title: 'Atari ショック',
        body: 'Atari 2600 ブーム後、北米の家庭用ゲーム市場は供給過多、品質低下、小売の不信で冷え込んだ。NES の復興はその修復から始まった。',
        images: ['/img/consoles/thumbs/atari-2600-hero-320.webp', '/img/consoles/thumbs/famicom-hero-320.webp'],
      },
      {
        href: '/features/16-bit-war/',
        title: '16ビット戦争',
        body: 'メガドライブはスピードと攻撃的な広告で任天堂に挑み、スーパーファミコンは色彩、音、RPG の厚みで主流を守った。ここから主機戦争はスペック表だけではなくなった。',
        images: ['/img/consoles/thumbs/super-famicom-hero-320.webp', '/img/consoles/thumbs/mega-drive-hero-320.webp'],
      },
      {
        href: '/features/playstation-breakup/',
        title: 'PlayStation 前夜',
        body: '任天堂と Sony の SFC CD-ROM 提携が破綻し、周辺機器計画は独立主機へ変わった。主機戦争は契約書から始まることもある。',
        images: ['/img/consoles/thumbs/super-famicom-hero-320.webp', '/img/consoles/thumbs/ps1-hero-320.webp'],
      },
      {
        href: '/features/polygon-revolution/',
        title: 'ポリゴン革命',
        body: 'PlayStation、Saturn、Nintendo 64 は、CD-ROM、3D 空間、メモリーカード、アナログ操作へ競争軸を移した。現代ゲームの輪郭はここで描かれた。',
        images: ['/img/consoles/thumbs/ps1-hero-320.webp', '/img/consoles/thumbs/n64-hero-320.webp'],
      },
      {
        href: '/features/sega-exit/',
        title: 'セガ、ハードから降りる',
        body: 'サターン 1995 年 E3 奇襲、32X とメガ CD による疲弊、そして PS2 の DVD によって沈んだドリームキャスト——セガがハードから降りた 7 年間の解体劇。',
        images: ['/img/consoles/thumbs/saturn-hero-320.webp', '/img/consoles/thumbs/dreamcast-hero-320.webp'],
      },
      {
        href: '/features/gray-memory/',
        title: '中華圏のグレー記憶',
        body: '小覇王、神遊機、Gamate、Super A\'Can、Watara Supervision——正規任天堂のタイムラインと並行して走り続けた、1987-2007 中華圏のグレーハード史。',
        images: ['/img/consoles/thumbs/famicom-hero-320.webp', '/img/consoles/thumbs/n64-hero-320.webp'],
      },
      {
        href: '/features/handheld-wars/',
        title: '携帯機戦争三部作',
        body: '1989 年ゲームボーイがモノクロでカラー Lynx を破り、2004 年 DS がタッチで PSP を逆転し、2011 年 Vita が iPhone に屠られる——携帯機戦争 30 年三幕史、最後に Switch が『戦場を降りる』ことで戦争を終わらせた。',
        images: ['/img/consoles/thumbs/game-boy-hero-320.webp', '/img/consoles/thumbs/nintendo-ds-hero-320.webp'],
      },
    ],
  },
}[lang];
---

<section class="py-12">
  <header class="mb-12 text-center">
    <p class="font-pixel text-xs tracking-widest text-crt-amber-dim">[ MUSEUM · DIRECTORY ]</p>
    <h1 class="mt-3 font-pixel text-3xl text-crt-amber crt-glow md:text-5xl">{t('site.title')}</h1>
    <p class="mt-5 mx-auto max-w-2xl text-sm text-crt-text/80 md:text-base">{t('site.tagline')}</p>
  </header>

  <ol class="relative space-y-6 before:absolute before:bottom-6 before:left-[2.05rem] before:top-4 before:w-px before:bg-gradient-to-b before:from-crt-amber/20 before:via-crt-amber-dim/70 before:to-crt-green/40 md:before:left-[9rem]">
    {timelineEntries.map((entry) => {
      const isHandheld = entry.branch === 'handheld';
      return (
        <li class="relative grid gap-4 pl-16 md:grid-cols-[8rem_minmax(0,1fr)] md:gap-8 md:pl-0">
          <span
            class:list={[
              'absolute left-[2.05rem] top-5 z-10 h-4 w-4 -translate-x-1/2 rounded-full border-2 bg-crt-bg shadow-[0_0_0_4px_rgba(10,10,10,0.92)] md:left-[9rem]',
              isHandheld ? 'border-crt-green' : 'border-crt-amber',
            ]}
          ></span>
          <div class="space-y-2 md:sticky md:top-24 md:self-start md:pr-2 md:text-right">
            <p
              class:list={[
                'font-mono text-[11px] uppercase tracking-[0.28em]',
                isHandheld ? 'text-crt-green/75' : 'text-crt-amber-dim',
              ]}
            >
              {entry.marker}
            </p>
            <div
              class:list={[
                'font-pixel text-2xl leading-tight md:text-3xl',
                isHandheld ? 'text-crt-green' : 'text-crt-amber crt-glow',
              ]}
            >
              {isHandheld ? 'H' : entry.key}
            </div>
            <div class="font-mono text-xs text-crt-text/50">{entry.info.period}</div>
          </div>
          <a
            href={entry.href}
            class:list={[
              'group relative block overflow-hidden rounded-xl border bg-crt-panel/35 p-5 transition md:p-6',
              isHandheld
                ? 'border-crt-green/25 hover:border-crt-green/55 hover:bg-crt-panel/55'
                : 'border-crt-dim/45 hover:border-crt-amber/60 hover:bg-crt-panel/60',
            ]}
          >
            <span
              class:list={[
                'absolute inset-y-0 left-0 w-1',
                isHandheld
                  ? 'bg-gradient-to-b from-crt-green/70 via-crt-green/30 to-transparent'
                  : 'bg-gradient-to-b from-crt-amber/70 via-crt-amber-dim/35 to-transparent',
              ]}
            ></span>
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="max-w-2xl">
                <h2
                  class:list={[
                    'font-pixel text-sm leading-relaxed md:text-base',
                    isHandheld ? 'text-crt-green' : 'text-crt-amber',
                  ]}
                >
                  {entry.info.titles[lang]}
                </h2>
              </div>
              <span
                class:list={[
                  'rounded-full border px-3 py-1 font-mono text-[11px] uppercase tracking-[0.22em]',
                  isHandheld ? 'border-crt-green/40 text-crt-green/80' : 'border-crt-dim/60 text-crt-amber-dim',
                ]}
              >
                {entry.count} {consoleLabel}
              </span>
            </div>
            <p class="mt-3 max-w-3xl text-sm leading-relaxed text-crt-text/78">{entry.info.summaries[lang]}</p>
          </a>
        </li>
      );
    })}
  </ol>

  <section class="mt-14 border-y border-crt-green/25 py-6">
    <p class="font-pixel text-xs tracking-widest text-crt-green/75">{featureCopies.eyebrow}</p>
    <div class="mt-5 grid gap-5 md:grid-cols-2">
      {featureCopies.items.map((feature) => (
        <a href={localizedPath(lang, feature.href)} class="group grid gap-5 border border-crt-dim/45 bg-crt-panel/25 p-5 transition hover:border-crt-amber/60 hover:bg-crt-panel/45">
          <div class="grid grid-cols-2 overflow-hidden border border-crt-dim/45 bg-crt-panel/35">
            {feature.images.map((src) => (
              <img src={src} alt="" class="aspect-video h-full w-full object-cover opacity-85 transition group-hover:opacity-100" loading="lazy" />
            ))}
          </div>
          <div>
            <h2 class="font-pixel text-lg leading-relaxed text-crt-amber crt-glow md:text-xl">{feature.title}</h2>
            <p class="mt-4 text-sm leading-relaxed text-crt-text/78">{feature.body}</p>
            <p class="mt-4 font-mono text-xs uppercase tracking-[0.22em] text-crt-amber-dim group-hover:text-crt-amber">
              {featureCopies.cta} →
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <p class="mt-12 text-center text-xs text-crt-text/40">— 千葉熊</p>
</section>
