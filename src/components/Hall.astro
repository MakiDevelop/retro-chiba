---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import { generations, allGenKeys } from '../data/generations';
import consolesData from '../data/consoles.json';

interface ConsoleEntry { gen: string; }

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const counts = (consolesData as ConsoleEntry[]).reduce<Record<string, number>>((acc, c) => {
  acc[c.gen] = (acc[c.gen] || 0) + 1;
  return acc;
}, {});

const consoleLabel = {
  'zh-tw': '台主機',
  'zh-cn': '台主机',
  en: 'consoles',
  ja: '機種',
}[lang];

const homeGens = allGenKeys.filter((g) => g !== 'h');
---

<section class="py-12">
  <header class="mb-12 text-center">
    <p class="font-pixel text-xs tracking-widest text-crt-amber-dim">[ MUSEUM · DIRECTORY ]</p>
    <h1 class="mt-3 font-pixel text-3xl text-crt-amber crt-glow md:text-5xl">{t('site.title')}</h1>
    <p class="mt-5 mx-auto max-w-2xl text-sm text-crt-text/80 md:text-base">{t('site.tagline')}</p>
  </header>

  <ol class="relative space-y-3 before:absolute before:left-3 before:top-2 before:bottom-2 before:w-px before:bg-crt-dim/40 md:before:left-4">
    {homeGens.map((g) => {
      const info = generations[g];
      const count = counts[g] || 0;
      return (
        <li class="relative pl-10 md:pl-14">
          <span class="absolute left-1.5 top-3 h-3 w-3 rounded-full border-2 border-crt-amber-dim bg-crt-bg md:left-2.5"></span>
          <a
            href={localizedPath(lang, `/generations/${g}/`)}
            class="block rounded border border-crt-dim/40 bg-crt-panel/30 p-5 transition hover:border-crt-amber/60 hover:bg-crt-panel/60"
          >
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <h2 class="font-pixel text-sm text-crt-amber md:text-base">{info.titles[lang]}</h2>
              <span class="font-mono text-xs text-crt-text/55">{info.period}</span>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-crt-text/75">{info.summaries[lang]}</p>
            <div class="mt-3 text-xs text-crt-amber-dim">
              {count} {consoleLabel} →
            </div>
          </a>
        </li>
      );
    })}

    <li class="relative pl-10 pt-4 md:pl-14">
      <span class="absolute left-1.5 top-7 h-3 w-3 rotate-45 border-2 border-crt-amber-dim bg-crt-bg md:left-2.5"></span>
      <a
        href={localizedPath(lang, '/generations/h/')}
        class="block rounded border border-crt-dim/40 bg-crt-panel/30 p-5 transition hover:border-crt-amber/60 hover:bg-crt-panel/60"
      >
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <h2 class="font-pixel text-sm text-crt-amber md:text-base">{generations.h.titles[lang]}</h2>
          <span class="font-mono text-xs text-crt-text/55">{generations.h.period}</span>
        </div>
        <p class="mt-2 text-sm leading-relaxed text-crt-text/75">{generations.h.summaries[lang]}</p>
        <div class="mt-3 text-xs text-crt-amber-dim">{counts.h || 0} {consoleLabel} →</div>
      </a>
    </li>
  </ol>

  <p class="mt-12 text-center text-xs text-crt-text/40">— 千葉熊</p>
</section>
